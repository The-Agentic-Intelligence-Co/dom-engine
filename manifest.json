{
  "manifest_version": 3,
  "name": "DOM Analyzer",
  "version": "1.0",
  "description": "Simple DOM analyzer extension",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Analyze DOM"
  },
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["browser/content.js"]
    }
  ]
}
